<?xml version="1.0"?>
<sdf version="1.7" xmlns:drake="drake.mit.edu">
  <model name="granny_smith_apple">
    <link name="granny_smith_apple">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <pose>7e-07 -1e-07 -6e-07 0 0 0</pose>
        <mass>0.2</mass>
        <inertia>
          <ixx> 0.000097</ixx>
          <ixy> 0.000002</ixy>
          <ixz>-0.000001</ixz>
          <iyy> 0.000103</iyy>
          <iyz> 0.000002</iyz>
          <izz> 0.000113</izz>
        </inertia>
      </inertial>
      <visual name="granny_smith_apple">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>/home/ubuntu/lbm_eval/lbm_eval_models/groceries/apples/assets/granny_smith_apple.gltf</uri>
            <scale>1.0 1.0 1.0</scale>
          </mesh>
        </geometry>
